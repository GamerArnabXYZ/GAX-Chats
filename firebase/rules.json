{
  "rules": {

    "admins": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('owner').val() === true",
      "$adminUid": {
        ".read": "auth != null && auth.uid === $adminUid",
        ".validate": "newData.isBoolean() || newData.hasChild('owner')",
        "owner": { ".validate": "newData.isBoolean()" }
      }
    },

    "users": {
      ".indexOn": ["username"],
      ".read":  "auth != null",
      ".write": false,
      "$uid": {
        ".read":     "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write":    "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".validate": "!newData.exists() || newData.hasChildren(['uid', 'name', 'username'])",
        "uid":      { ".read": "auth != null", ".validate": "newData.isString() && newData.val() === $uid && (!data.exists() || data.val() === newData.val())" },
        "name":     { ".read": "auth != null", ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
        "username": { ".read": "auth != null", ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20 && newData.val().matches(/^[a-z0-9_]+$/)" },
        "pfp":      { ".read": "auth != null", ".validate": "newData.isString() && (newData.val().length === 0 || (newData.val().length <= 500 && newData.val().matches(/^https:\\/\\/.+/)))" },
        "bio":      { ".read": "auth != null", ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 120)" },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= (now + 60000)" },
        "status": {
          ".read":     "auth != null",
          ".write":    "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'online' || newData.val() === 'offline'))"
        },
        "lastSeen": {
          ".read":     "auth != null",
          ".write":    "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= (now + 60000))"
        },
        "friends": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          "$fid": {
            ".write":    "auth != null && $uid !== $fid && (auth.uid === $uid || auth.uid === $fid || root.child('admins').child(auth.uid).val() === true) && (root.child('users').child($fid).exists() || !newData.exists())",
            ".validate": "!newData.exists() || newData.val() === true"
          }
        },
        "req": {
          ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
          "$senderUid": {
            ".write":    "auth != null && $uid !== $senderUid && (root.child('admins').child(auth.uid).val() === true || (auth.uid === $uid) || (auth.uid === $senderUid && !root.child('users').child($uid).child('friends').child($senderUid).exists()))",
            ".validate": "!newData.exists() || newData.val() === true"
          }
        },
        "$unknownField": { ".validate": false }
      }
    },

    "messages": {
      "$chatId": {
        ".read":  "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
        ".write": false,
        "$msgId": {
          ".write":    "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
          ".validate": "newData.hasChildren(['senderId', 'timestamp', 'type'])",
          "senderId":  { ".validate": "(newData.isString() && newData.val() === auth.uid) || root.child('admins').child(auth.uid).val() === true" },
          "timestamp": { ".validate": "newData.isNumber() && newData.val() <= (now + 60000)" },
          "text":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
          "type":      { ".validate": "newData.isString() && (newData.val() === 'text' || newData.val() === 'image' || newData.val() === 'link')" },
          "read":      { ".validate": "!newData.exists() || newData.isBoolean()" },
          "forwarded": { ".validate": "!newData.exists() || newData.isBoolean()" },
          "reactions": {
            "$reactorUid": {
              ".write":    "auth != null && auth.uid === $reactorUid",
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 8)"
            }
          },
          "replyTo": {
            ".validate": "!newData.exists() || newData.hasChildren(['senderId', 'text', 'type'])",
            "senderId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
            "text":     { ".validate": "newData.isString() && newData.val().length <= 4000" },
            "type":     { ".validate": "newData.isString() && newData.val().length <= 20" }
          },
          "$unknownMsgField": { ".validate": false }
        }
      }
    },

    "chats": {
      "$chatId": {
        ".read":  "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
        "members":       { "$uid": { ".validate": "!newData.exists() || newData.val() === true" } },
        "lastMsg":       { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" },
        "lastMsgType":   { ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'text' || newData.val() === 'image' || newData.val() === 'link'))" },
        "lastMsgSender": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 128)" },
        "lastTs":        { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= (now + 60000))" },
        "updatedAt":     { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= (now + 60000))" },
        "pinned":        { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)" },
        "unread": {
          "$uid": {
            ".read":     "auth != null && (auth.uid === $uid || $chatId.contains(auth.uid) || root.child('admins').child(auth.uid).val() === true)",
            ".write":    "auth != null && ($chatId.contains(auth.uid) || root.child('admins').child(auth.uid).val() === true)",
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
          }
        },
        "$unknownChatField": { ".validate": false }
      }
    },

    "typing": {
      "$chatId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
        "$uid": {
          ".write":    "auth != null && auth.uid === $uid && $chatId.contains(auth.uid)",
          ".validate": "!newData.exists() || newData.isBoolean()"
        }
      }
    },

    "config": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('owner').val() === true",
      "ownerUid":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
      "appVersion": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
      "motd":       { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
      "supportUids": { "$uid": { ".validate": "!newData.exists() || newData.val() === true" } },
      "$unknownConfigField": { ".validate": false }
    },

    "feedback_tags": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$chatId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
        "$msgId": {
          ".write":    "auth != null && (root.child('admins').child(auth.uid).val() === true || $chatId.contains(auth.uid))",
          ".validate": "newData.hasChildren(['type', 'uid', 'ts'])",
          "type":      { ".validate": "newData.isString() && (newData.val() === 'bug' || newData.val() === 'feature' || newData.val() === 'feedback')" },
          "uid":       { ".validate": "(newData.isString() && newData.val() === auth.uid) || root.child('admins').child(auth.uid).val() === true" },
          "ts":        { ".validate": "newData.isNumber() && newData.val() <= (now + 60000)" },
          "resolved":  { ".write": "auth != null && root.child('admins').child(auth.uid).val() === true", ".validate": "newData.isBoolean()" },
          "adminReply":{ ".write": "auth != null && root.child('admins').child(auth.uid).val() === true", ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
          "$unknownTagField": { ".validate": false }
        }
      }
    },

    "$other": {
      ".read":  false,
      ".write": false
    }

  }
}
